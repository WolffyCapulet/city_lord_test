function getStoredShopQty(bucket, id, fallback=1){
  const store = (state.ui && state.ui[bucket] && typeof state.ui[bucket] === 'object') ? state.ui[bucket] : {};
  return Math.max(1, Math.floor(toFiniteNumber(store[id], fallback)));
}
